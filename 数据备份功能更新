function renderStudents(){const g=currentGroup();const meta=currentGroupMeta();const main=document.getElementById('main');let html=`<div class="panel"><div class="panel-header"><div><div class="panel-title">学生名单 · ${escapeHtml(meta.course)} · ${escapeHtml(meta.label)}</div><div class="panel-subtitle">${meta.capacity?'应选 '+meta.capacity+' 人 · ':''}当前 ${g.students.length} 人<span id="stu-search-stats"></span></div></div><div class="btn-group"><button class="btn" onclick="downloadCsvTemplate()">下载模板</button><button class="btn" onclick="document.getElementById('roster-file').click()">导入名单</button><button class="btn primary" onclick="addStudentModal()">添加学生</button><input type="file" id="roster-file" style="display:none" accept=".csv,.xlsx,.xls" onchange="handleRosterImport(event)"></div></div>`;if(g.students.length)html+=`<div class="search-bar"><input id="stu-search" type="search" placeholder="🔍 搜索学号 / 姓名 / 行政班..." value="${escapeHtml(studentSearch)}" oninput="if(!this.dataset.composing)onStudentSearch(this.value)" oncompositionstart="this.dataset.composing='1'" oncompositionend="this.dataset.composing='';onStudentSearch(this.value)" autocomplete="off"><button id="stu-search-clear" class="btn sm" onclick="clearStudentSearch()" style="display:${studentSearch?'inline-flex':'none'}">清除</button></div><div class="bulk-actions"><span class="text-sm muted">批量删除：</span>${meta.adminClasses.map(c=>{const n=g.students.filter(s=>s.adminClass===c).length;return`<button class="btn sm danger" onclick="bulkDeleteByClass('${c}')" ${n===0?'disabled':''}>清空 ${escapeHtml(c)} (${n}人)</button>`}).join('')}<button class="btn sm danger" onclick="bulkDeleteAll()">清空当前教学班 (${g.students.length}人)</button></div>`;html+=`<div id="stu-list-region"></div></div>`;main.innerHTML=html;refreshStudentList()}
function refreshStudentList(){const g=currentGroup();if(!g)return;const region=document.getElementById('stu-list-region');if(!region)return;const q=studentSearch.trim().toLowerCase();const filteredStu=q?g.students.filter(s=>(s.studentId||'').toLowerCase().includes(q)||(s.name||'').toLowerCase().includes(q)||(s.adminClass||'').toLowerCase().includes(q)):g.students;const stats=document.getElementById('stu-search-stats');if(stats)stats.textContent=q?' · 搜索匹配 '+filteredStu.length+' 人':'';const cb=document.getElementById('stu-search-clear');if(cb)cb.style.display=studentSearch?'inline-flex':'none';let html='';if(!g.students.length){html=`<div class="empty">还没有学生<br><span class="text-sm">点击"导入名单"上传 Excel/CSV，或"下载模板"获取格式</span></div>`}else if(!filteredStu.length){html=`<div class="empty">没有匹配「${escapeHtml(studentSearch)}」的学生<br><button class="btn sm" style="margin-top:12px" onclick="clearStudentSearch()">清除搜索</button></div>`}else{html=`<div class="table-wrap"><table><thead><tr><th>#</th><th>学号</th><th>姓名</th><th>行政班</th><th></th></tr></thead><tbody>`;filteredStu.forEach((s,i)=>{html+=`<tr><td class="muted">${i+1}</td><td>${escapeHtml(s.studentId)}</td><td>${escapeHtml(s.name)}</td><td><span class="tag">${escapeHtml(s.adminClass)}</span></td><td><div class="btn-group"><button class="btn sm primary" onclick="openStudentEditor('${s.studentId}')">查看/编辑</button><button class="btn sm danger" onclick="removeStudent('${s.studentId}')">删除</button></div></td></tr>`});html+=`</tbody></table></div>`}region.innerHTML=html}
function onStudentSearch(v){studentSearch=v;refreshStudentList()}
function clearStudentSearch(){studentSearch='';const si=document.getElementById('stu-search');if(si){si.value='';si.focus()}refreshStudentList()}
function openStudentEditor(sid){const g=currentGroup();const meta=currentGroupMeta();const stu=g.students.find(s=>s.studentId===sid);if(!stu){hideModal();return}const sc=computeScores(state.currentGroupId,sid);const f=g.finals[sid]||{raw:'',coef:1};let rowsHtml='';g.sessions.forEach((s,i)=>{const r=s.records[sid]||{};const att=r.attendance||'';const ans=r.answers||0,ga=r.goodAnswers||0;const hw=r.homework||'';const perf=r.performance||'';rowsHtml+=`<tr><td><strong>第${s.num}次</strong>${s.hasHomework?' <span class="tag" style="background:var(--gold-soft);border-color:rgba(184,146,61,.3);color:var(--gold);margin-left:4px">作业</span>':''}</td><td><select class="mini-sel" onchange="editRec('${sid}',${i},'attendance',this.value)"><option value="">—</option><option value="present" ${att==='present'?'selected':''}>到课</option><option value="late" ${att==='late'?'selected':''}>迟到</option><option value="leave" ${att==='leave'?'selected':''}>请假</option><option value="absent" ${att==='absent'?'selected':''}>旷课</option></select></td><td><input type="number" min="0" step="1" value="${ans}" onchange="editRec('${sid}',${i},'answers',this.value)" class="mini-num"></td><td><input type="number" min="0" step="1" value="${ga}" onchange="editRec('${sid}',${i},'goodAnswers',this.value)" class="mini-num"></td><td>${s.hasHomework?`<select class="mini-sel" onchange="editRec('${sid}',${i},'homework',this.value)"><option value="">—</option><option value="submitted" ${hw==='submitted'?'selected':''}>已交</option><option value="missing" ${hw==='missing'?'selected':''}>未交 -5</option></select>`:'<span class="muted text-sm">—</span>'}</td><td><select class="mini-sel" onchange="editRec('${sid}',${i},'performance',this.value)"><option value="">—</option><option value="focus" ${perf==='focus'?'selected':''}>认真 +1</option><option value="distract" ${perf==='distract'?'selected':''}>走神 -1</option></select></td></tr>`});const adminClassOpts=meta.adminClasses.map(c=>`<option value="${escapeHtml(c)}" ${stu.adminClass===c?'selected':''}>${escapeHtml(c)}</option>`).join('');showModal(`<div class="edit-modal"><h2>编辑学生数据 <span class="muted text-sm" style="font-weight:400">${escapeHtml(stu.name)} · ${escapeHtml(stu.studentId)}</span></h2><div class="hint" style="margin-bottom:12px">改动即时保存，并同步到考勤、课堂、期末、汇总等所有页面。</div><div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:10px;margin-bottom:14px"><div class="field" style="margin:0"><label>学号</label><input value="${escapeHtml(stu.studentId)}" onchange="editStuBasic('${sid}','studentId',this.value)"></div><div class="field" style="margin:0"><label>姓名</label><input value="${escapeHtml(stu.name)}" onchange="editStuBasic('${sid}','name',this.value)"></div><div class="field" style="margin:0"><label>行政班</label>${meta.adminClasses.length?`<select onchange="editStuBasic('${sid}','adminClass',this.value)">${adminClassOpts}<option value="__other__">其他…</option></select>`:`<input value="${escapeHtml(stu.adminClass)}" onchange="editStuBasic('${sid}','adminClass',this.value)">`}</div></div><div class="stats-grid" style="margin-bottom:14px"><div class="stat-card"><div class="stat-label">到课率</div><div class="stat-value">${(sc.attRate*100).toFixed(0)}%</div></div><div class="stat-card"><div class="stat-label">加分小计</div><div class="stat-value">${sc.bonusSum>=0?'+':''}${sc.bonusSum}</div></div><div class="stat-card"><div class="stat-label">总评</div><div class="stat-value">${sc.total!=null?sc.total.toFixed(1):'—'}</div></div></div><div style="display:flex;gap:10px;margin-bottom:10px;flex-wrap:wrap"><div class="field" style="margin:0;flex:1;min-width:120px"><label>期末原始分</label><input type="number" min="0" max="150" step="0.1" value="${f.raw??''}" onchange="editFinal('${sid}','raw',this.value)"></div><div class="field" style="margin:0;flex:1;min-width:120px"><label>折算系数</label><input type="number" min="0" max="2" step="0.01" value="${f.coef??1}" onchange="editFinal('${sid}','coef',this.value)"></div></div><div class="table-wrap" style="max-height:46vh;overflow:auto"><table><thead><tr><th>课次</th><th>出勤</th><th>回答+1</th><th>精彩+2</th><th>作业</th><th>表现</th></tr></thead><tbody>${rowsHtml}</tbody></table></div><div style="display:flex;justify-content:flex-end;gap:6px;margin-top:14px"><button class="btn primary" onclick="hideModal();renderStudents()">完成</button></div></div>`)}
function editRec(sid,idx,field,val){const g=currentGroup();const s=g.sessions[idx];if(!s)return;if(!s.records[sid])s.records[sid]={};const r=s.records[sid];if(field==='answers'||field==='goodAnswers'){const n=Math.max(0,parseInt(val)||0);if(n===0)delete r[field];else r[field]=n}else{if(!val)delete r[field];else r[field]=val}if(!Object.keys(r).length)delete s.records[sid];saveState();openStudentEditor(sid)}
function editStuBasic(sid,field,val){const g=currentGroup();const stu=g.students.find(s=>s.studentId===sid);if(!stu)return;val=String(val||'').trim();if(field==='studentId'){if(!val){toast('学号不能为空');openStudentEditor(sid);return}if(val===sid)return;if(g.students.find(s=>s.studentId===val)){alert('学号 '+val+' 已存在');openStudentEditor(sid);return}stu.studentId=val;g.sessions.forEach(s=>{if(s.records[sid]){s.records[val]=s.records[sid];delete s.records[sid]}});if(g.finals[sid]){g.finals[val]=g.finals[sid];delete g.finals[sid]}saveState();openStudentEditor(val);return}if(field==='adminClass'&&val==='__other__'){val=prompt('输入行政班名称');if(!val){openStudentEditor(sid);return}val=val.trim()}stu[field]=val;saveState();openStudentEditor(sid)}
function editFinal(sid,field,val){const g=currentGroup();if(!g.finals[sid])g.finals[sid]={raw:'',coef:1};if(field==='raw')g.finals[sid].raw=val===''?'':Number(val);else g.finals[sid].coef=Number(val);saveState();openStudentEditor(sid)}
function addStudentModal(){const meta=currentGroupMeta();showModal(`<h2>添加学生</h2><form id="add-stu" onsubmit="submitAddStudent(event)"><div class="field"><label>学号 *</label><input name="studentId" required></div><div class="field"><label>姓名 *</label><input name="name" required></div><div class="field"><label>行政班 *</label>${meta.adminClasses.length?`<select name="adminClass" required>${meta.adminClasses.map(c=>`<option>${escapeHtml(c)}</option>`).join('')}<option value="__other__">其他…</option></select>`:`<input name="adminClass" required>`}</div><div style="display:flex;justify-content:flex-end;gap:6px;margin-top:14px"><button type="button" class="btn" onclick="hideModal()">取消</button><button type="submit" class="btn primary">添加</button></div></form>`)}
function submitAddStudent(e){e.preventDefault();const fd=new FormData(e.target);let adminClass=fd.get('adminClass');if(adminClass==='__other__'){adminClass=prompt('输入行政班名称');if(!adminClass)return}const g=currentGroup();const sid=fd.get('studentId').trim();if(g.students.find(s=>s.studentId===sid)){alert('学号已存在');return}g.students.push({studentId:sid,name:fd.get('name').trim(),adminClass:adminClass.trim()});saveState();hideModal();renderStudents();toast('已添加')}
function removeStudent(sid){if(!confirm('确定删除该学生？相关考勤、作业、期末记录都会清除。'))return;const g=currentGroup();g.students=g.students.filter(s=>s.studentId!==sid);g.sessions.forEach(s=>delete s.records[sid]);delete g.finals[sid];saveState();renderStudents();toast('已删除')}
function bulkDeleteByClass(adminClass){const g=currentGroup();const targets=g.students.filter(s=>s.adminClass===adminClass);if(!targets.length)return;if(!confirm(`确定删除 ${adminClass} 的全部 ${targets.length} 名学生？\n相关考勤、答题、作业、表现、期末记录都会清除，且不可恢复。`))return;if(!confirm(`再次确认：将永久删除 ${adminClass} 的 ${targets.length} 人。\n建议提前到【数据备份】导出 JSON。`))return;const ids=new Set(targets.map(s=>s.studentId));g.students=g.students.filter(s=>!ids.has(s.studentId));g.sessions.forEach(sess=>{for(const id of ids)delete sess.records[id]});for(const id of ids)delete g.finals[id];saveState();renderMain();toast(`已删除 ${adminClass} 的 ${targets.length} 人`)}
function bulkDeleteAll(){const g=currentGroup();const n=g.students.length;if(!n)return;if(!confirm(`确定删除当前教学班的全部 ${n} 名学生？\n所有记录都会清除，且不可恢复。`))return;if(!confirm(`再次确认：将永久删除 ${n} 人。\n建议提前到【数据备份】导出 JSON。`))return;g.students=[];g.sessions.forEach(s=>{s.records={}});g.finals={};saveState();renderMain();toast(`已清空全部 ${n} 人`)}
function downloadCsvTemplate(){const csv='\ufeff学号,姓名,行政班\n20240101,张三,示例班级2401\n20240102,李四,示例班级2401\n';const blob=new Blob([csv],{type:'text/csv;charset=utf-8'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='学生名单模板.csv';a.click();URL.revokeObjectURL(a.href)}

function handleRosterImport(ev){const file=ev.target.files[0];if(!file)return;const ext=file.name.split('.').pop().toLowerCase();const reader=new FileReader();reader.onload=e=>{try{let rows;if(ext==='csv'){let text;const buf=e.target.result;if(typeof buf==='string')text=buf;else{const dec=new TextDecoder('utf-8',{fatal:false});text=dec.decode(buf);if(text.charCodeAt(0)===0xFEFF)text=text.slice(1);const looksMojibake=/\uFFFD/.test(text)||(!/[一-龥]/.test(text)&&/[\x80-\xFF]/.test(new Uint8Array(buf).reduce((a,b)=>a+String.fromCharCode(b),'')));if(looksMojibake){try{text=new TextDecoder('gbk').decode(buf)}catch(_){try{text=new TextDecoder('gb18030').decode(buf)}catch(__){}}}}rows=parseCSV(text)}else{const wb=XLSX.read(e.target.result,{type:'array'});const ws=wb.Sheets[wb.SheetNames[0]];rows=XLSX.utils.sheet_to_json(ws,{header:1,defval:''})}importStudents(rows,file.name)}catch(err){showImportError(file.name,'读取文件失败：'+err.message)}finally{ev.target.value=''}};if(ext==='csv')reader.readAsArrayBuffer(file);else reader.readAsArrayBuffer(file)}
function parseCSV(text){const rows=[];let cur=[],field='',inQ=false;for(let i=0;i<text.length;i++){const c=text[i];if(inQ){if(c==='"'&&text[i+1]==='"'){field+='"';i++}else if(c==='"')inQ=false;else field+=c}else{if(c==='"')inQ=true;else if(c===','){cur.push(field);field=''}else if(c==='\n'||c==='\r'){if(c==='\r'&&text[i+1]==='\n')i++;cur.push(field);if(cur.some(x=>x!==''))rows.push(cur);cur=[];field=''}else field+=c}}if(field!==''||cur.length){cur.push(field);if(cur.some(x=>x!==''))rows.push(cur)}return rows}
function importStudents(rows,filename){if(!rows||!rows.length){showImportError(filename,'文件是空的');return}const head=rows[0].map(x=>String(x||'').trim());const findCol=(...names)=>{for(let i=0;i<head.length;i++){const h=head[i].toLowerCase();for(const n of names){if(h===n||h.includes(n))return i}}return-1};const idCol=findCol('学号','studentid','student id','id','学籍号','sno');const nameCol=findCol('姓名','name','学生姓名','student name');const classCol=findCol('行政班','班级','class','行政班级','adminclass','admin class');if(idCol<0||nameCol<0){showImportError(filename,`未识别到必要的列。表头是：${head.join(' | ')}\n需要至少包含：学号、姓名。如有"行政班"列也会被读取，没有则使用教学班默认班级。`);return}const meta=currentGroupMeta();const defaultClass=meta.adminClasses[0]||'未分班';const g=currentGroup();const existing=new Set(g.students.map(s=>s.studentId));let added=0,skipped=0,duplicates=0;const skippedReasons=[];for(let i=1;i<rows.length;i++){const r=rows[i];if(!r||r.every(x=>!String(x||'').trim()))continue;const sid=String(r[idCol]||'').trim();const name=String(r[nameCol]||'').trim();const ac=classCol>=0?String(r[classCol]||'').trim():defaultClass;if(!sid||!name){skipped++;skippedReasons.push(`第${i+1}行：缺少学号或姓名`);continue}if(existing.has(sid)){duplicates++;continue}g.students.push({studentId:sid,name,adminClass:ac||defaultClass});existing.add(sid);added++}saveState();renderStudents();if(added===0){showImportError(filename,`导入 0 人，跳过 ${skipped+duplicates} 行\n${duplicates?`重复学号 ${duplicates} 条；`:''}${skippedReasons.length?'问题示例：\n  '+skippedReasons.slice(0,5).join('\n  '):''}`);return}toast(`已导入 ${added} 人${duplicates?`，跳过重复 ${duplicates} 条`:''}${skipped?`，跳过问题行 ${skipped} 条`:''}`)}
function showImportError(filename,msg){showModal(`<h2>导入失败</h2><p class="muted text-sm">${escapeHtml(filename)}</p><pre style="white-space:pre-wrap;background:var(--bg);padding:10px;border-radius:6px;font-size:12px;margin-top:8px;border:1px solid var(--border)">${escapeHtml(msg)}</pre><div style="display:flex;justify-content:flex-end;margin-top:14px"><button class="btn" onclick="hideModal()">关闭</button></div>`)}

// ====== 数据备份 ======
function renderBackup(){const main=document.getElementById('main');const size=new Blob([localStorage.getItem(STORAGE_KEY)||'']).size;const sizeStr=size>1024?(size/1024).toFixed(1)+' KB':size+' B';const last=state.lastBackup?new Date(state.lastBackup).toLocaleString('zh-CN'):'从未';const legacy=hasLegacyData();main.innerHTML=`<div class="panel"><div class="panel-header"><div><div class="panel-title">数据备份</div><div class="panel-subtitle">本地存储 · ${sizeStr} · 上次备份：${last}</div></div></div>${legacy?`<div class="legacy-banner"><div class="text">检测到本浏览器中保存有 <strong>上一版工具</strong> 的数据。两版备份格式互通，可一键迁移过来。</div><button class="btn gold" onclick="importLegacyFromBrowser()">↩ 从上一版导入</button></div>`:''}<div class="hint">所有数据存在浏览器 localStorage 里。建议<strong>每周导出一次 JSON 备份</strong>，学期末再导出一次 Excel 归档。换设备 / 清缓存前一定要备份！<br><br>本版本与<strong>上一版「考勤与成绩管理」</strong>的 JSON 备份<strong>完全互通</strong>——可在两个工具之间自由迁移数据。</div><div class="btn-group" style="margin-top:14px;gap:10px"><button class="btn primary" onclick="exportJSON()">📥 导出 JSON 备份</button><button class="btn" onclick="document.getElementById('json-import').click()">📤 导入 JSON 文件</button><input type="file" id="json-import" accept="*/*" style="display:none" onchange="importJSON(event)"><button class="btn" onclick="importJsonByPaste()">📋 粘贴 JSON 文本</button><button class="btn danger" onclick="clearAllData()">🗑️ 清空所有数据</button></div></div>`}
function exportJSON(){const data=JSON.stringify(state,null,2);const blob=new Blob([data],{type:'application/json'});const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download=`考勤成绩备份_${new Date().toISOString().slice(0,10)}.json`;a.click();URL.revokeObjectURL(a.href);state.lastBackup=new Date().toISOString();saveState();toast('已导出备份');renderMain()}
function normalizeSettings(s){if(!s)return{...DEFAULT_SETTINGS};return{attendanceMax:typeof s.attendanceMax==='number'?s.attendanceMax:20,finalRatio:typeof s.finalRatio==='number'?s.finalRatio:(typeof s.finalWeight==='number'?s.finalWeight:0.8),totalCap:typeof s.totalCap==='number'?s.totalCap:(typeof s.processCap==='number'?s.processCap:100)}}
function importJSON(ev){const file=ev.target.files[0];if(!file)return;if(!confirm('导入会覆盖当前所有数据，是否继续？建议先导出当前数据。'))return;const reader=new FileReader();reader.onload=e=>{try{const data=JSON.parse(e.target.result);if(!data.courseGroups||!Array.isArray(data.courseGroups))throw new Error('文件格式不对');state={...state,...data,settings:normalizeSettings(data.settings)};migrateHasHomework();saveState();renderMain();toast('已导入 '+data.courseGroups.length+' 个教学班')}catch(err){alert('导入失败：'+err.message)}};reader.readAsText(file);ev.target.value=''}
function importJsonByPaste(){showModal(`<h2>粘贴 JSON 备份内容</h2><div class="hint" style="margin-bottom:12px">手机上找不到 JSON 文件？在<strong>电脑</strong>上用记事本（或任何文本编辑器）打开备份文件，全选（Ctrl+A）复制（Ctrl+C），用微信发给手机，然后长按消息复制，粘贴到下方文本框即可。</div><div class="field"><textarea id="json-paste-area" style="min-height:220px;font-family:monospace;font-size:12px;width:100%" placeholder='{&quot;courseGroups&quot;:[...],&quot;groups&quot;:{...},...}'></textarea></div><div style="display:flex;justify-content:flex-end;gap:6px;margin-top:6px"><button class="btn" onclick="hideModal()">取消</button><button class="btn primary" onclick="applyJsonPaste()">导入</button></div>`)}
function applyJsonPaste(){const txt=document.getElementById('json-paste-area').value.trim();if(!txt){toast('请先粘贴内容');return}let data;try{data=JSON.parse(txt)}catch(err){alert('解析失败，确认是完整有效的 JSON：'+err.message);return}if(!data.courseGroups||!Array.isArray(data.courseGroups)){alert('内容格式不对，缺少 courseGroups 字段');return}if(!confirm('导入会覆盖当前所有数据，是否继续？'))return;try{state={...state,...data,settings:normalizeSettings(data.settings)};migrateHasHomework();saveState();hideModal();renderMain();toast('已导入 '+data.courseGroups.length+' 个教学班')}catch(err){alert('导入失败：'+err.message)}}
function hasLegacyData(){try{const raw=localStorage.getItem(LEGACY_STORAGE_KEY);if(!raw)return false;const d=JSON.parse(raw);return d&&Array.isArray(d.courseGroups)&&d.courseGroups.length>0}catch(_){return false}}
function importLegacyFromBrowser(){const raw=localStorage.getItem(LEGACY_STORAGE_KEY);if(!raw){toast('未检测到上一版数据');return}if(!confirm('将导入上一版「考勤与成绩管理」在本浏览器里保存的数据。\n这会覆盖当前所有数据，是否继续？'))return;try{const data=JSON.parse(raw);if(!data.courseGroups||!Array.isArray(data.courseGroups))throw new Error('上一版数据为空或不可读');state={...state,...data,settings:normalizeSettings(data.settings)};migrateHasHomework();saveState();renderMain();toast('已从上一版导入 '+data.courseGroups.length+' 个教学班')}catch(err){alert('导入失败：'+err.message)}}
function clearAllData(){if(!confirm('确定要清空所有数据吗？这不可恢复！'))return;if(!confirm('再次确认：所有教学班、学生、考勤、成绩都会删除。'))return;localStorage.removeItem(STORAGE_KEY);location.reload()}

// ====== Excel 导出 ======
function exportExcel(){const g=currentGroup();const meta=currentGroupMeta();const wb=XLSX.utils.book_new();const classes=meta.adminClasses.length?meta.adminClasses:['全部'];classes.forEach(cls=>{const stus=g.students.filter(s=>meta.adminClasses.length?s.adminClass===cls:true);const rows=[];rows.push(['学号','姓名','行政班','到课','迟到','请假','旷课','到课率','回答(+1)','精彩回答(+2)','作业课次','已交','未交','认真','走神','考勤分(20)','期末原始','折算系数','期末折算(80)','答题分','作业分','表现分','加分小计','总评']);let hwSessions=0;for(const ss of g.sessions)if(ss.hasHomework)hwSessions++;stus.forEach(stu=>{const sc=computeScores(state.currentGroupId,stu.studentId);let an=0,ag=0,hp=0,hm=0,pc=0,pd=0;for(const s of g.sessions){const r=s.records[stu.studentId]||{};an+=r.answers||0;ag+=r.goodAnswers||0;if(s.hasHomework){if(r.homework==='submitted')hp++;if(r.homework==='missing')hm++}if(r.performance==='focus')pc++;if(r.performance==='distract')pd++}const f=g.finals[stu.studentId]||{};rows.push([stu.studentId,stu.name,stu.adminClass,sc.attCounts.present,sc.attCounts.late,sc.attCounts.leave,sc.attCounts.absent,(sc.attRate*100).toFixed(1)+'%',an,ag,hwSessions,hp,hm,pc,pd,+sc.attScore.toFixed(2),f.raw??'',f.coef??'',sc.finalScaled!=null?+sc.finalScaled.toFixed(2):'',sc.answerScore,sc.hwScore,sc.perfScore,sc.bonusSum,sc.total!=null?+sc.total.toFixed(2):''])});const ws=XLSX.utils.aoa_to_sheet(rows);XLSX.utils.book_append_sheet(wb,ws,cls.slice(0,30))});XLSX.writeFile(wb,`${meta.course}_${meta.label}_${new Date().toISOString().slice(0,10)}.xlsx`);toast('Excel 已导出')}

// ====== 帮助函数 ======
function escapeHtml(s){return String(s??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;','\'':'&#39;'}[c]))}
function showModal(html){const root=document.getElementById('modal-root');root.innerHTML=`<div class="modal-bg" onclick="if(event.target===this)hideModal()"><div class="modal">${html}</div></div>`}
function hideModal(){document.getElementById('modal-root').innerHTML=''}
function toast(msg){const el=document.getElementById('toast');el.textContent=msg;el.classList.add('show');clearTimeout(window._toastTimer);window._toastTimer=setTimeout(()=>el.classList.remove('show'),2000)}

// ====== 启动 ======
loadState();renderMain();if(hasLegacyData()&&!state.courseGroups.length)setTimeout(()=>toast('检测到上一版数据，可在【数据备份】或【课程设置】一键迁移'),600);
</script>
